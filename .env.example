# Copy to .env and fill in. .env is gitignored; this template is NOT — keep it placeholder-only.

# --- OpenCode Go (OpenAI-compatible model provider) ---
OPENCODE_API_KEY=
OPENCODE_MODEL=kimi-k2
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# --- Telegram bot (create via @BotFather; get chat id via `python3 harness.py --tg-updates`) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google Places API (New/v1) key, billing enabled ---
GOOGLE_PLACES_API_KEY=

# --- Optional ---
DAILY_CALORIE_TARGET=2100
