# Copy to .env and fill in. .env is gitignored; this template is NOT — keep it placeholder-only.

# --- OpenCode Go (OpenAI-compatible model provider) ---
OPENCODE_API_KEY=
OPENCODE_MODEL=kimi-k2
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# --- Telegram bot (create via @BotFather; get chat id via `python3 harness.py --tg-updates`) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google Places API (New/v1) key, billing enabled ---
GOOGLE_PLACES_API_KEY=

# --- Vercel webhook only (set these as Vercel env vars, not needed locally) ---
# Fine-grained PAT with Contents read/write on this repo:
GITHUB_TOKEN=
GITHUB_REPO=Weiming95/lunch-harness
GITHUB_BRANCH=main
# Random string; also passed to Telegram setWebhook as secret_token:
TELEGRAM_WEBHOOK_SECRET=
# Writable scratch dir on Vercel:
LUNCH_DATA_DIR=/tmp/lh/data
LUNCH_DOCS_DIR=/tmp/lh/docs

# --- Optional ---
DAILY_CALORIE_TARGET=2100
